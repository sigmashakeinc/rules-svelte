# svelte_write_safety.rules
# Technology: svelte | Capability: write

rule svelte-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_svelte_PATTERN"
  MESSAGE "Blocked an unsafe pattern in svelte. Use the recommended best practices for 2025/2026."
}

rule svelte-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_svelte_API"
  MESSAGE "You are using an outdated API for svelte. Please upgrade to the newer API."
}
